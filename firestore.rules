rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Fields: uid, name, email, role, photo, instrument, location, phone
    //
    // Collection: lessons
    // Fields: studentId, mentorId, date, time, status, type
    //
    // Collection: notifications
    // Fields: userId, type, title, body, read, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "thivyyya@gmail.com" && request.auth.token.email_verified == true));
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 100 &&
             data.email is string &&
             data.role in ['student', 'mentor'];
    }

    function isValidLesson(data) {
      return data.keys().hasAll(['studentId', 'mentorId', 'date', 'time', 'status']) &&
             data.status in ['pending', 'confirmed', 'completed', 'cancelled'];
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'type', 'title', 'body', 'read', 'createdAt']);
    }

    // Rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /lessons/{lessonId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId);
      allow create: if isAuthenticated() && isValidLesson(request.resource.data) && (request.auth.uid == request.resource.data.studentId || request.auth.uid == request.resource.data.mentorId);
      allow update: if isAuthenticated() && isValidLesson(request.resource.data) && (request.auth.uid == resource.data.studentId || request.auth.uid == resource.data.mentorId);
    }

    match /notifications/{notificationId} {
      allow read: if isAuthenticated() && request.auth.uid == resource.data.userId;
      allow create: if isAuthenticated() && isValidNotification(request.resource.data);
      allow update: if isAuthenticated() && request.auth.uid == resource.data.userId && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['read']);
    }
  }
}
